Ques7: Odd sum and even sum of array
Ans:
public class a18_odd_even_sum {
    public static void main(String[] args) {
        int arr[] = {5,10,15,20,25};
        int oddsum = 0;
        int evensum = 0;

        for(int i=0 ; i<=4 ; i++){
            if(arr[i]%2 == 0){
                evensum = evensum + arr[i];
            }else{
                oddsum = oddsum + arr[i];
            }
        }
        System.out.println("evensum =" + evensum );
        System.out.println("oddsum ="+ oddsum);
    }
}
