public class a20_reverse_str {
    public static void main(String[] args) {
        String str = "Ansh Batra";
        String reversed  =" ";
        for(int i = str.length() -1 ; i>=0; i--){
            reversed = reversed + str.charAt(i);
        }
        System.out.println(reversed);
    }
